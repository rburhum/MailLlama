# ----- Database -----
# SQLite by default; swap to Postgres by changing the URL + installing .[postgres]
DATABASE_URL=sqlite:///mailllama.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/mailllama

# ----- Cache / task queue (optional) -----
# If unset, MailLlama uses a sqlite-backed KV + in-process task runner.
# Set REDIS_URL and install .[redis] to use Redis + Huey.
REDIS_URL=

# ----- LLM (OpenAI-compatible) -----
# Point this at your SSH-tunneled local LLM (vLLM / llama.cpp server / Ollama /v1).
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_API_KEY=local
LLM_MODEL=gemma4:26b
# Optional: a cheaper/faster model for sender-batch classification
LLM_MODEL_CLASSIFY=

# ----- Optional SSH tunnel -----
# If your LLM runs on a remote server reachable by SSH, MailLlama can open
# `ssh -N -L <local>:<remote_host>:<remote_port> <host>` automatically.
# Your SSH client must already be able to connect to SSH_TUNNEL_HOST
# without a password (keys / agent / ~/.ssh/config alias).
SSH_TUNNEL_ENABLED=false
SSH_TUNNEL_HOST=                                  # e.g. tenerife
SSH_TUNNEL_LOCAL_PORT=11434
SSH_TUNNEL_REMOTE_HOST=127.0.0.1
SSH_TUNNEL_REMOTE_PORT=11434
SSH_TUNNEL_EXTRA_ARGS=

# ----- Mail provider -----
# gmail_api | imap
MAIL_PROVIDER=gmail_api

# Gmail API (OAuth2) — required for MAIL_PROVIDER=gmail_api
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://127.0.0.1:8000/auth/gmail/callback

# IMAP — required for MAIL_PROVIDER=imap
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# ----- Security -----
# Fernet key used to encrypt stored OAuth tokens. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# ----- Web server -----
BIND_HOST=127.0.0.1
BIND_PORT=8000
# Set to a random string to require a simple bearer token (Authorization: Bearer <token>)
WEB_AUTH_TOKEN=

# ----- Behavior -----
# If true, actions are logged but not executed against the mail provider.
DRY_RUN=false
